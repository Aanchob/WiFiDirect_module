<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ui"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="NOVA Chat"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
        <SolidColorBrush x:Key="AppInkBrush" Color="#F3F7FA" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="#A8B5BE" />
        <SolidColorBrush x:Key="SubtleInkBrush" Color="#6F7E89" />
        <SolidColorBrush x:Key="PanelBrush" Color="#9911161C" />
        <SolidColorBrush x:Key="PanelStrongBrush" Color="#D012171E" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#66192028" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#24313B45" />
        <SolidColorBrush x:Key="StrokeBrightBrush" Color="#334B6574" />
        <SolidColorBrush x:Key="AccentBrush" Color="#00D6FF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#2A00D6FF" />
        <SolidColorBrush x:Key="LimeBrush" Color="#B8FF6A" />
        <SolidColorBrush x:Key="LimeSoftBrush" Color="#2CB8FF6A" />
        <SolidColorBrush x:Key="IncomingBubbleBrush" Color="#E01A222C" />
        <SolidColorBrush x:Key="InputBrush" Color="#D0161D25" />

        <LinearGradientBrush x:Key="PageGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2213E8FF" Offset="0" />
            <GradientStop Color="#0611161C" Offset="0.45" />
            <GradientStop Color="#1A9FFF68" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="OutgoingBubbleBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF00C7F2" Offset="0" />
            <GradientStop Color="#FF3FF087" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="TinyLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleInkBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="IconOnlyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="Background" Value="#20182028" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
            <Setter Property="Background" Value="#18182028" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        </Grid.Resources>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0A0D12" Offset="0" />
                <GradientStop Color="#FF0F151C" Offset="0.45" />
                <GradientStop Color="#FF09110D" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Rectangle Fill="{StaticResource PageGlowBrush}" Opacity="0.95" />

        <Grid Margin="16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="460" />
                <ColumnDefinition Width="300" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="22">
                <Grid Padding="18" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="14" BorderBrush="#5500D6FF" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF00D6FF" Offset="0" />
                                    <GradientStop Color="#FFB8FF6A" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Foreground="#FF081018" Text="N" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="NOVA Chat" />
                            <TextBlock Style="{StaticResource MetaTextStyle}" Text="卒研チーム / オンライン" />
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource IconOnlyButtonStyle}">
                            <FontIcon FontSize="16" Glyph="&#xE712;" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Height="44" Background="{StaticResource InputBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="14">
                        <Grid Padding="13,0" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{StaticResource SubtleInkBrush}" Glyph="&#xE721;" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource SubtleInkBrush}" Text="会話、ファイル、メンバーを検索" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TinyLabelStyle}" Text="⌘K" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Background="{StaticResource AccentSoftBrush}" BorderBrush="#6600D6FF" BorderThickness="1" CornerRadius="10" Foreground="{StaticResource AccentBrush}" Height="34" Content="すべて" />
                        <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Content="未読" />
                        <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}" Content="ピン" />
                    </Grid>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="9">
                            <TextBlock Margin="2,4,0,2" Style="{StaticResource TinyLabelStyle}" Text="PINNED" />

                            <Border Background="#332A3843" BorderBrush="#6600D6FF" BorderThickness="1" CornerRadius="16" Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <Ellipse Width="42" Height="42" Fill="#FF182732" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="AI" />
                                        <Ellipse Width="10" Height="10" Margin="0,0,1,1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="{StaticResource LimeBrush}" Stroke="#FF11161C" StrokeThickness="2" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="AI研究ミーティング" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="UI案、かなり良くなってきた" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="7">
                                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource TinyLabelStyle}" Text="13:42" />
                                        <Border MinWidth="22" Height="22" Background="{StaticResource AccentBrush}" CornerRadius="11">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#FF061016" Text="4" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <Ellipse Width="42" Height="42" Fill="#FF222A36" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFD36A" Text="ST" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="進捗相談" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="発表資料の導線を確認したい" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Top" Style="{StaticResource TinyLabelStyle}" Text="12:08" />
                                </Grid>
                            </Border>

                            <TextBlock Margin="2,8,0,2" Style="{StaticResource TinyLabelStyle}" Text="DIRECT MESSAGES" />

                            <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <Ellipse Width="42" Height="42" Fill="#FF25203A" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#FFC9B8FF" Text="MY" />
                                        <Ellipse Width="10" Height="10" Margin="0,0,1,1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="{StaticResource LimeBrush}" Stroke="#FF11161C" StrokeThickness="2" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Miyu" />
                                        <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="動画デモ、今日撮れそう" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Top" Style="{StaticResource TinyLabelStyle}" Text="11:51" />
                                </Grid>
                            </Border>

                            <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <Ellipse Width="42" Height="42" Fill="#FF1C3027" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource LimeBrush}" Text="RN" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Ren" />
                                        <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="レビューコメント置いた" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="2" MinWidth="22" Height="22" VerticalAlignment="Center" Background="{StaticResource LimeBrush}" CornerRadius="11">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#FF081018" Text="1" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <Ellipse Width="42" Height="42" Fill="#FF34202B" />
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#FFFF8CC6" Text="AK" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Akari" />
                                        <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="了解、あとで合わせよう" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Top" Style="{StaticResource TinyLabelStyle}" Text="昨日" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="4" Background="#26192028" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="34" Height="34" Fill="#FF00D6FF" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Bosto" />
                                <TextBlock FontSize="11" Foreground="{StaticResource LimeBrush}" Text="集中モード" />
                            </StackPanel>
                            <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource MutedInkBrush}" Glyph="&#xE713;" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelStrongBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="22">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="116" />
                    </Grid.RowDefinitions>

                    <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="22,0">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid VerticalAlignment="Center">
                                <Ellipse Width="48" Height="48" Fill="#FF182732" />
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="AI" />
                                <Ellipse Width="12" Height="12" Margin="0,0,1,1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="{StaticResource LimeBrush}" Stroke="#FF11161C" StrokeThickness="2" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="AI研究ミーティング" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Style="{StaticResource MetaTextStyle}" Text="6人参加中" />
                                    <TextBlock Style="{StaticResource MetaTextStyle}" Text="•" />
                                    <TextBlock Foreground="{StaticResource LimeBrush}" FontSize="12" Text="Miyu が入力中" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconOnlyButtonStyle}">
                                    <FontIcon FontSize="16" Glyph="&#xE717;" />
                                </Button>
                                <Button Style="{StaticResource IconOnlyButtonStyle}">
                                    <FontIcon FontSize="16" Glyph="&#xE720;" />
                                </Button>
                                <Button Style="{StaticResource IconOnlyButtonStyle}">
                                    <FontIcon FontSize="16" Glyph="&#xE8B7;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="22,18" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16">
                            <Border HorizontalAlignment="Center" Background="#24182028" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="12" Padding="12,5">
                                <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="今日 7月3日" />
                            </Border>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="34" Height="34" VerticalAlignment="Top" Fill="#FF25203A" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Miyu" />
                                        <TextBlock Style="{StaticResource TinyLabelStyle}" Text="13:21" />
                                    </StackPanel>
                                    <Border MaxWidth="560" HorizontalAlignment="Left" Background="{StaticResource IncomingBubbleBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="4,16,16,16" Padding="14,11">
                                        <TextBlock FontSize="14" Foreground="{StaticResource AppInkBrush}" Text="UIの方向性、卒研っぽい堅さよりも「実際に使いたくなる研究支援チャット」に寄せるの良さそう。" TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="34" Height="34" VerticalAlignment="Top" Fill="#FF1C3027" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Ren" />
                                        <TextBlock Style="{StaticResource TinyLabelStyle}" Text="13:24" />
                                    </StackPanel>
                                    <Border MaxWidth="560" HorizontalAlignment="Left" Background="{StaticResource IncomingBubbleBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="4,16,16,16" Padding="14,11">
                                        <TextBlock FontSize="14" Foreground="{StaticResource AppInkBrush}" Text="右側にプロフィールと共有資料があると、会話を見ながら文脈を追える。けっこう使いやすい。" TextWrapping="Wrap" />
                                    </Border>
                                    <Border Width="320" HorizontalAlignment="Left" Background="#2A00D6FF" BorderBrush="#6600D6FF" BorderThickness="1" CornerRadius="14" Padding="12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="42" Height="42" Background="#3300D6FF" CornerRadius="12">
                                                <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="{StaticResource AccentBrush}" Glyph="&#xE8A5;" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="research-outline.pdf" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource MutedInkBrush}" Text="2.4 MB • さっき共有" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <StackPanel HorizontalAlignment="Right" Spacing="6">
                                <Border MaxWidth="560" Background="{StaticResource OutgoingBubbleBrush}" CornerRadius="16,4,16,16" Padding="14,11">
                                    <TextBlock FontSize="14" Foreground="#FF061016" Text="いいね。左は会話の切り替えを速く、中央は読む/返すに集中、右は資料と状態確認、という役割に分けたい。" TextWrapping="Wrap" />
                                </Border>
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Style="{StaticResource TinyLabelStyle}" Text="13:31" />
                                    <TextBlock Foreground="{StaticResource LimeBrush}" FontSize="11" Text="既読 5" />
                                </StackPanel>
                            </StackPanel>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="34" Height="34" VerticalAlignment="Top" Fill="#FF34202B" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Akari" />
                                        <TextBlock Style="{StaticResource TinyLabelStyle}" Text="13:36" />
                                    </StackPanel>
                                    <Border MaxWidth="560" HorizontalAlignment="Left" Background="{StaticResource IncomingBubbleBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="4,16,16,16" Padding="14,11">
                                        <TextBlock FontSize="14" Foreground="{StaticResource AppInkBrush}" Text="入力欄もちゃんとアプリっぽくしたい。添付、絵文字、音声、送信がすぐ分かる感じ。" TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <StackPanel HorizontalAlignment="Right" Spacing="6">
                                <Border MaxWidth="560" Background="{StaticResource OutgoingBubbleBrush}" CornerRadius="16,4,16,16" Padding="14,11">
                                    <TextBlock FontSize="14" Foreground="#FF061016" Text="了解。見た目だけじゃなくて、どこを押せばいいか一瞬で分かる密度にする。" TextWrapping="Wrap" />
                                </Border>
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Style="{StaticResource TinyLabelStyle}" Text="13:39" />
                                    <TextBlock Foreground="{StaticResource LimeBrush}" FontSize="11" Text="既読 5" />
                                </StackPanel>
                            </StackPanel>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid VerticalAlignment="Top">
                                    <Ellipse Width="34" Height="34" Fill="#FF25203A" />
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#FFC9B8FF" Text="MY" />
                                </Grid>
                                <Border Grid.Column="1" Width="96" HorizontalAlignment="Left" Background="{StaticResource IncomingBubbleBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="4,16,16,16" Padding="13,10">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource MutedInkBrush}" Opacity="0.95" />
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource MutedInkBrush}" Opacity="0.65" />
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource MutedInkBrush}" Opacity="0.35" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,1,0,0" Padding="18">
                        <Grid Background="{StaticResource InputBrush}" BorderBrush="{StaticResource StrokeBrightBrush}" BorderThickness="1" CornerRadius="18" Padding="12" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource IconOnlyButtonStyle}">
                                <FontIcon FontSize="16" Glyph="&#xE723;" />
                            </Button>
                            <Button Grid.Column="1" Style="{StaticResource IconOnlyButtonStyle}">
                                <FontIcon FontSize="16" Glyph="&#xE76E;" />
                            </Button>
                            <TextBox Grid.Column="2" MinHeight="42" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="{StaticResource AppInkBrush}" PlaceholderText="メッセージを入力..." />
                            <Button Grid.Column="3" Style="{StaticResource IconOnlyButtonStyle}">
                                <FontIcon FontSize="16" Glyph="&#xE720;" />
                            </Button>
                            <Button Grid.Column="4" Style="{StaticResource IconOnlyButtonStyle}">
                                <FontIcon FontSize="16" Glyph="&#xE1D6;" />
                            </Button>
                            <Button Grid.Column="5" Width="46" Height="42" Padding="0" BorderBrush="#8800D6FF" BorderThickness="1" CornerRadius="14" Foreground="#FF061016">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF00D6FF" Offset="0" />
                                        <GradientStop Color="#FFB8FF6A" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                                <FontIcon FontSize="17" Glyph="&#xE724;" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="22">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="18" Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="詳細" />
                            <Button Grid.Column="1" Style="{StaticResource IconOnlyButtonStyle}">
                                <FontIcon FontSize="15" Glyph="&#xE713;" />
                            </Button>
                        </Grid>

                        <StackPanel HorizontalAlignment="Center" Spacing="10">
                            <Grid>
                                <Ellipse Width="96" Height="96" Fill="#FF182732" />
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="AI" />
                                <Ellipse Width="18" Height="18" Margin="0,0,8,8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="{StaticResource LimeBrush}" Stroke="#FF11161C" StrokeThickness="3" />
                            </Grid>
                            <TextBlock HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="AI研究ミーティング" />
                            <Border Background="{StaticResource LimeSoftBrush}" BorderBrush="#55B8FF6A" BorderThickness="1" CornerRadius="12" Padding="10,5">
                                <TextBlock FontSize="12" Foreground="{StaticResource LimeBrush}" Text="アクティブ • 6人オンライン" />
                            </Border>
                        </StackPanel>

                        <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="今日のフォーカス" />
                                <TextBlock FontSize="13" Foreground="{StaticResource MutedInkBrush}" Text="発表デモに使うチャットUIを、研究支援ツールとして自然に見えるところまで磨く。" TextWrapping="Wrap" />
                                <ProgressBar Height="6" Maximum="100" Value="72" Foreground="{StaticResource AccentBrush}" Background="#22313B45" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Height="40" Background="{StaticResource AccentSoftBrush}" BorderBrush="#6600D6FF" BorderThickness="1" CornerRadius="12" Foreground="{StaticResource AccentBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                                    <TextBlock Text="通話" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Height="40" Background="{StaticResource LimeSoftBrush}" BorderBrush="#55B8FF6A" BorderThickness="1" CornerRadius="12" Foreground="{StaticResource LimeBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                                    <TextBlock Text="共有" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource TinyLabelStyle}" Text="SHARED FILES" />
                            <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="#2A00D6FF" CornerRadius="10">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" Glyph="&#xE8A5;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="research-outline.pdf" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="{StaticResource MutedInkBrush}" Text="Ren • 2.4 MB" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38" Background="#2CB8FF6A" CornerRadius="10">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource LimeBrush}" Glyph="&#xE9F9;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="demo-flow.fig" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="{StaticResource MutedInkBrush}" Text="Miyu • 8分前" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource TinyLabelStyle}" Text="MEMBERS" />
                            <StackPanel Spacing="8">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="30" Height="30" Fill="#FF25203A" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource AppInkBrush}" Text="Miyu" />
                                    <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{StaticResource LimeBrush}" />
                                </Grid>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="30" Height="30" Fill="#FF1C3027" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource AppInkBrush}" Text="Ren" />
                                    <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{StaticResource LimeBrush}" />
                                </Grid>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="30" Height="30" Fill="#FF34202B" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource AppInkBrush}" Text="Akari" />
                                    <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{StaticResource SubtleInkBrush}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
