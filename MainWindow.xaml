<Window
    x:Class="direct_module.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="20" Spacing="10">

        <Button
        Content="待ち受け開始"
        Click="StartListener_Click"/>

        <Button
        Content="Wi-Fi Direct探索開始"
        Click="SearchButton_Click"/>

        <Button
        Content="BLE広告開始"
        Click="StartBleAdvertise_Click"/>

        <Button
        Content="BLEスキャン開始"
        Click="StartBleScan_Click"/>
        
        <Button
        Content="TCP待ち受け開始"
        Click="StartTcpServer_Click"/>

        <Button
        Content="選択した相手にTCP送信"
        Click="SendTcpToSelected_Click"/>

        <Button
        Content="選択した相手に接続"
        Click="ConnectSelected_Click"/>

        <TextBlock Text="見つかった相手"/>

        <ListView
        x:Name="PeerList"
        Height="200">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Text="ログ"/>

        <ListView
        x:Name="LogList"
        Height="200"/>

    </StackPanel>

</Window>