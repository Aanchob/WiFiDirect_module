<Window
    x:Class="direct_module.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Direct Module Chat">

    <Grid Padding="18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="相手を探す"
                    Click="SearchPeers_Click" />

                <Button
                    Grid.Column="1"
                    Content="接続"
                    Click="ConnectSelected_Click" />

                <Button
                    Grid.Column="2"
                    Content="TCP待ち受け開始"
                    Click="StartTcpServer_Click" />

                <Button
                    Grid.Column="3"
                    Content="ログ消去"
                    Click="ClearLog_Click" />
            </Grid>

            <Expander
                Grid.Row="1"
                Header="詳細操作 / 検証用">
                <Grid ColumnSpacing="8" RowSpacing="8" Padding="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="Wi-Fi Direct広告+待ち受け"
                        Click="StartListener_Click" />

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        Content="AssociationEndpoint探索"
                        Click="SearchButton_Click" />

                    <Button
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="通常Wi-Fi Direct探索"
                        Click="SearchDefaultButton_Click" />

                    <Button
                        Grid.Row="0"
                        Grid.Column="3"
                        Content="BLE広告開始"
                        Click="StartBleAdvertise_Click" />

                    <Button
                        Grid.Row="0"
                        Grid.Column="4"
                        Content="BLEスキャン開始"
                        Click="StartBleScan_Click" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="手入力IP" />

                    <TextBox
                        x:Name="TargetIpTextBox"
                        Grid.Row="1"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        PlaceholderText="例: 192.168.1.23" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="3"
                        Content="送信"
                        Click="SendTcpToSelected_Click" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="4"
                        Content="ログ末尾へ"
                        Click="ScrollLogBottom_Click" />
                </Grid>
            </Expander>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Text="見つかった相手"
                    FontSize="18"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="PeerList"
                    Grid.Row="1"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,6"
                                Text="{Binding DisplayText}"
                                TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Text="チャット"
                    FontSize="18"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="MessageList"
                    Grid.Row="1" />

                <Grid Grid.Row="2" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="MessageTextBox"
                        MinHeight="42"
                        PlaceholderText="メッセージを入力"
                        Text="Hello" />

                    <Button
                        x:Name="SendMessageButton"
                        Grid.Column="1"
                        MinWidth="100"
                        Content="送信"
                        Click="SendTcpToSelected_Click" />
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="通信ログ"
                    FontSize="16"
                    FontWeight="SemiBold" />

                <Button
                    Grid.Column="1"
                    Content="末尾へ"
                    Click="ScrollLogBottom_Click" />
            </Grid>

            <TextBox
                x:Name="LogTextBox"
                Grid.Row="1"
                AcceptsReturn="True"
                FontFamily="Consolas"
                FontSize="12"
                IsReadOnly="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                TextWrapping="NoWrap" />
        </Grid>
    </Grid>
</Window>
