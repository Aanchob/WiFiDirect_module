<Window
    x:Class="direct_module.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="20" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側：操作とPeerList -->
        <StackPanel Grid.Column="0" Spacing="10">

            <Button
            Content="待ち受け開始"
            Click="StartListener_Click"/>

            <Button
            Content="Wi-Fi Direct探索開始"
            Click="SearchButton_Click"/>

            <Button
            Content="BLE広告開始"
            Click="StartBleAdvertise_Click"/>

            <Button
            Content="BLEスキャン開始"
            Click="StartBleScan_Click"/>

            <Button
            Content="選択した相手に接続"
            Click="ConnectSelected_Click"/>

            <Button
            Content="TCP待ち受け開始"
            Click="StartTcpServer_Click"/>

            <TextBlock Text="相手のIPアドレス"/>

            <TextBox
            x:Name="TargetIpTextBox"
            PlaceholderText="例: 192.168.1.23"/>

            <Button
            Content="選択した相手にTCP送信"
            Click="SendTcpToSelected_Click"/>

            <TextBlock
            Text="見つかった相手"
            FontWeight="Bold"
            Margin="0,10,0,0"/>

            <ListView
            x:Name="PeerList"
            Height="250">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>

        <!-- 右側：ログ -->
        <StackPanel Grid.Column="1" Spacing="10">

            <TextBlock
            Text="ログ"
            FontWeight="Bold"/>

            <ListView
            x:Name="LogList"/>

        </StackPanel>
    </Grid>

</Window>