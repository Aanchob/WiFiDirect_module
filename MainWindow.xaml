<Window
    x:Class="direct_module.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="20" RowSpacing="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- 上：ボタン類 -->
        <StackPanel
        Grid.Row="0"
        Orientation="Horizontal"
        Spacing="8">

            <Button
            Content="待ち受け開始"
            Click="StartListener_Click"/>

            <Button
            Content="Wi-Fi Direct探索開始"
            Click="SearchButton_Click"/>

            <Button
            Content="BLE広告開始"
            Click="StartBleAdvertise_Click"/>

            <Button
            Content="BLEスキャン開始"
            Click="StartBleScan_Click"/>

            <Button
            Content="選択した相手に接続"
            Click="ConnectSelected_Click"/>

            <Button
    Content="TCP待ち受け開始"
    Click="StartTcpServer_Click"/>

            <TextBlock Text="相手のIPアドレス"/>

            <TextBox
    x:Name="TargetIpTextBox"
    PlaceholderText="例: 192.168.1.23"/>

            <Button
    Content="選択した相手にTCP送信"
    Click="SendTcpToSelected_Click"/>

            <Button
            Content="ログ消去"
            Click="ClearLog_Click"/>

        </StackPanel>

        <!-- 中央：PeerList -->
        <StackPanel
        Grid.Row="1"
        Spacing="8">

            <TextBlock
            Text="見つかった相手"
            FontWeight="Bold"/>

            <ListView
            x:Name="PeerList">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>

        <!-- 下：ログ -->
        <Border
        Grid.Row="2"
        BorderThickness="1"
        Padding="8">

            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="8">

                    <TextBlock
                    Text="ログ"
                    FontWeight="Bold"/>

                    <Button
                    Content="最新へ"
                    Click="ScrollLogBottom_Click"/>

                </StackPanel>

                <ListView
                x:Name="LogList"
                Grid.Row="1"/>

            </Grid>
        </Border>

    </Grid>
</Window>