<Window
    x:Class="direct_module.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="240"/>
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            RowSpacing="8"
            ColumnSpacing="8">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button
                Grid.Row="0"
                Grid.Column="0"
                Content="Wi-Fi Direct広告+待ち受け"
                Click="StartListener_Click"/>

            <Button
                Grid.Row="0"
                Grid.Column="1"
                Content="AssociationEndpoint探索"
                Click="SearchButton_Click"/>

            <Button
                Grid.Row="0"
                Grid.Column="2"
                Content="通常Wi-Fi Direct探索"
                Click="SearchDefaultButton_Click"/>

            <Button
                Grid.Row="0"
                Grid.Column="3"
                Content="BLE広告開始"
                Click="StartBleAdvertise_Click"/>

            <Button
                Grid.Row="1"
                Grid.Column="0"
                Content="BLEスキャン開始"
                Click="StartBleScan_Click"/>

            <Button
                Grid.Row="1"
                Grid.Column="1"
                Content="選択した相手に接続"
                Click="ConnectSelected_Click"/>

            <Button
                Grid.Row="1"
                Grid.Column="2"
                Content="TCP待ち受け開始"
                Click="StartTcpServer_Click"/>

            <Button
                Grid.Row="1"
                Grid.Column="3"
                Content="選択した相手へTCP送信"
                Click="SendTcpToSelected_Click"/>

            <Button
                Grid.Row="2"
                Grid.Column="0"
                Content="ログ消去"
                Click="ClearLog_Click"/>
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnSpacing="12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                RowSpacing="8">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8">

                    <TextBlock
                        Text="手入力IP"
                        VerticalAlignment="Center"/>

                    <TextBox
                        x:Name="TargetIpTextBox"
                        Width="180"
                        PlaceholderText="例: 192.168.1.23"/>
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Text="見つかった相手"
                    FontWeight="Bold"/>

                <ListView
                    x:Name="PeerList"
                    Grid.Row="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid
                Grid.Column="1"
                RowSpacing="8">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="チャット"
                    FontWeight="Bold"/>

                <ListView
                    x:Name="MessageList"
                    Grid.Row="1"/>

                <StackPanel
                    Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="8">

                    <TextBox
                        x:Name="MessageTextBox"
                        Width="300"
                        Text="Hello"/>

                    <Button
                        x:Name="SendMessageButton"
                        Content="送信"
                        Click="SendTcpToSelected_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            BorderThickness="1"
            Padding="8">

            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8">

                    <TextBlock
                        Text="ログ"
                        FontWeight="Bold"
                        VerticalAlignment="Center"/>

                    <Button
                        Content="末尾へ"
                        Click="ScrollLogBottom_Click"/>
                </StackPanel>

                <TextBox
                    x:Name="LogTextBox"
                    Grid.Row="1"
                    IsReadOnly="True"
                    AcceptsReturn="True"
                    TextWrapping="NoWrap"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
