namespace direct_module.CoreTests;

public sealed class FileTransferServiceTests
{
    [Fact]
    public async Task ConstructorIsIoLightAndInboundTransfersFailClosedUntilReady()
    {
        using var temp = new TestDirectory();
        string attachments = System.IO.Path.Combine(temp.Path, "not-created-yet", "attachments");
        var service = new FileTransferService(
            attachments,
            System.IO.Path.Combine(temp.Path, "downloads"),
            System.IO.Path.Combine(temp.Path, "outgoing"));

        Assert.False(Directory.Exists(attachments));
        await Assert.ThrowsAsync<InvalidOperationException>(
            () => service.HandleFileStartAsync(
                CreateStart(0),
                "authenticated:peer-not-ready",
                TestContext.Current.CancellationToken));
        Assert.False(Directory.Exists(attachments));

        service.EnsureStorageReady();
        ChatMessage start = CreateStart(0);
        await service.HandleFileStartAsync(
            start,
            "authenticated:peer-not-ready",
            TestContext.Current.CancellationToken);
        Assert.True(await service.AbortIncomingTransferAsync(
            start.FileId!,
            "authenticated:peer-not-ready",
            TestContext.Current.CancellationToken));
    }

    [Fact]
    public async Task OneSourceCannotConsumeAllGlobalTransferSlots()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";

        for (int index = 0; index < FileTransferService.MaxIncomingTransfersPerSource; index++)
        {
            await service.HandleFileStartAsync(
                CreateStart(0),
                source,
                TestContext.Current.CancellationToken);
        }

        await Assert.ThrowsAsync<InvalidOperationException>(
            () => service.HandleFileStartAsync(
                CreateStart(0),
                source,
                TestContext.Current.CancellationToken));
        Assert.Equal(
            FileTransferService.MaxIncomingTransfersPerSource,
            await service.AbortIncomingTransfersForSourceAsync(
                source,
                TestContext.Current.CancellationToken));
    }

    [Fact]
    public async Task OneSourceCannotRapidlyCreateUnlimitedCompletedFiles()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-rate-limited";

        for (int index = 0; index < FileTransferService.MaxIncomingStartsPerSourcePerMinute; index++)
        {
            ChatMessage start = CreateStart(0);
            await service.HandleFileStartAsync(
                start,
                source,
                TestContext.Current.CancellationToken);
            Assert.True(await service.AbortIncomingTransferAsync(
                start.FileId!,
                source,
                TestContext.Current.CancellationToken));
        }

        await Assert.ThrowsAsync<InvalidOperationException>(
            () => service.HandleFileStartAsync(
                CreateStart(0),
                source,
                TestContext.Current.CancellationToken));
    }

    [Fact]
    public async Task InvalidChunkImmediatelyAbortsAndDeletesPartialFile()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(1);
        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);

        ChatMessage invalid = CreateChunk(start, 0, "%%%%");

        await Assert.ThrowsAsync<InvalidDataException>(
            () => service.HandleFileChunkAsync(
                invalid,
                source,
                TestContext.Current.CancellationToken));
        await Assert.ThrowsAsync<InvalidDataException>(
            () => service.HandleFileEndAsync(
                CreateEnd(start),
                source,
                TestContext.Current.CancellationToken));
        Assert.Empty(Directory.EnumerateFiles(service.AttachmentsDirectory, ".incoming-*.part"));
    }

    [Fact]
    public async Task FileNameTruncationNeverSplitsSurrogatePairs()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        ChatMessage start = CreateStart(0);
        start.FileName = new string('a', 178) + "😀.txt";

        FileTransferDisplayResult result = Assert.IsType<FileTransferDisplayResult>(
            await service.HandleFileStartAsync(
                start,
                "authenticated:peer-a",
                TestContext.Current.CancellationToken));

        Assert.InRange(result.FileName.Length, 1, 180);
        _ = new UTF8Encoding(false, true).GetBytes(result.FileName);
        await service.AbortAllIncomingTransfersAsync(TestContext.Current.CancellationToken);
    }

    [Theory]
    [InlineData("group")]
    [InlineData("conversation")]
    [InlineData("size")]
    [InlineData("count")]
    [InlineData("name")]
    public async Task ChunkEnvelopeMutationAbortsTransfer(string mutation)
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-envelope";
        ChatMessage start = CreateStart(0);
        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);

        ChatMessage chunk = CreateChunk(start, 0, "");
        MutateEnvelope(chunk, mutation);

        await Assert.ThrowsAsync<InvalidDataException>(
            () => service.HandleFileChunkAsync(
                chunk,
                source,
                TestContext.Current.CancellationToken));
        Assert.Empty(Directory.EnumerateFiles(service.AttachmentsDirectory, ".incoming-*.part"));
    }

    [Theory]
    [InlineData("group")]
    [InlineData("conversation")]
    [InlineData("size")]
    [InlineData("count")]
    [InlineData("name")]
    [InlineData("size-null")]
    [InlineData("count-null")]
    [InlineData("name-null")]
    public async Task EndEnvelopeMutationCannotCompleteOrAcknowledgeTransfer(string mutation)
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-envelope";
        ChatMessage start = CreateStart(0);
        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);
        await service.HandleFileChunkAsync(
            CreateChunk(start, 0, ""),
            source,
            TestContext.Current.CancellationToken);

        ChatMessage end = CreateEnd(start);
        MutateEnvelope(end, mutation);

        await Assert.ThrowsAsync<InvalidDataException>(
            () => service.HandleFileEndAsync(
                end,
                source,
                TestContext.Current.CancellationToken));
        Assert.Empty(Directory.EnumerateFiles(service.AttachmentsDirectory, ".incoming-*.part"));
        Assert.Empty(Directory.EnumerateFiles(service.AttachmentsDirectory, "sample*"));
    }

    [Fact]
    public async Task ConsistentRelayedGroupEnvelopeCompletesNormally()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:group-owner";
        ChatMessage start = CreateStart(0);
        start.IsGroup = true;
        start.ConversationId = "group:all-peers:v1";
        start.RelaySenderId = "peer:44444444444444444444444444444444";
        start.RelaySenderName = "Group owner";
        start.RelayShortSessionId = "C3D4";
        start.HopCount = 1;

        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);
        await service.HandleFileChunkAsync(
            CreateChunk(start, 0, ""),
            source,
            TestContext.Current.CancellationToken);
        FileTransferDisplayResult completed = Assert.IsType<FileTransferDisplayResult>(
            await service.HandleFileEndAsync(
                CreateEnd(start),
                source,
                TestContext.Current.CancellationToken));

        Assert.True(File.Exists(completed.LocalFilePath));
    }

    [Fact]
    public void AcknowledgementBindsTargetAndActualSender()
    {
        var transfer = new ChatMessage
        {
            Type = "file_end",
            SenderId = "peer:original-sender",
            FileId = Guid.NewGuid().ToString("N"),
            IsGroup = true,
            ConversationId = "group:default"
        };

        ChatMessage message = FileTransferService.CreateAcknowledgement(
            transfer,
            "peer:receiver",
            "Receiver",
            "ABCD",
            success: true);

        Assert.True(FileTransferService.TryParseAcknowledgement(message, out FileTransferAcknowledgement parsed));
        Assert.Equal("peer:original-sender", parsed.AcknowledgementTargetId);
        Assert.Equal("peer:receiver", parsed.AcknowledgementSenderId);

        message.AcknowledgementSenderId = "peer:spoofed";
        Assert.False(FileTransferService.TryParseAcknowledgement(message, out _));
    }

    [Fact]
    public void AcknowledgementErrorRemovesControlAndFormattingCharacters()
    {
        var transfer = new ChatMessage
        {
            SenderId = "peer:sender",
            FileId = Guid.NewGuid().ToString("N")
        };
        ChatMessage message = FileTransferService.CreateAcknowledgement(
            transfer,
            "peer:receiver",
            "Receiver",
            "ABCD",
            success: false,
            errorMessage: "bad\r\n\u202Eerror\u2066");

        Assert.True(FileTransferService.TryParseAcknowledgement(message, out FileTransferAcknowledgement parsed));
        Assert.Equal("baderror", parsed.ErrorMessage);
    }

    [Theory]
    [InlineData("file_start")]
    [InlineData("file_chunk")]
    public async Task FailedOutboundDispatchTerminatesRemoteSessionsAndPreservesPrimaryError(
        string failingType)
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        string filePath = System.IO.Path.Combine(temp.Path, "outbound.bin");
        File.WriteAllBytes(filePath, new byte[] { 0x42 });
        var sentTypes = new List<string>();
        var primary = new InvalidOperationException("primary dispatch failure");

        Task SendAsync(ChatMessage message, CancellationToken cancellationToken)
        {
            cancellationToken.ThrowIfCancellationRequested();
            sentTypes.Add(message.Type);
            if (string.Equals(message.Type, failingType, StringComparison.Ordinal))
            {
                return Task.FromException(primary);
            }
            if (string.Equals(message.Type, "file_abort", StringComparison.Ordinal))
            {
                return Task.FromException(new IOException("cleanup dispatch failure"));
            }
            return Task.CompletedTask;
        }

        InvalidOperationException failure = await Assert.ThrowsAsync<InvalidOperationException>(
            () => service.SendFileConfirmedAsync(
                filePath,
                "peer:11111111111111111111111111111111",
                "Sender",
                "A1B2",
                isGroup: false,
                conversationId: "peer:22222222222222222222222222222222",
                sendAsync: SendAsync,
                waitForAcknowledgementAsync: (_, _) => Task.FromException<FileTransferAcknowledgement>(
                    new InvalidOperationException("acknowledgement must not be awaited")),
                cancellationToken: TestContext.Current.CancellationToken));

        Assert.Same(primary, failure);
        Assert.Equal("file_start", sentTypes[0]);
        Assert.Equal("file_abort", sentTypes[^1]);
        Assert.Equal(
            failingType == "file_start"
                ? new[] { "file_start", "file_abort" }
                : new[] { "file_start", "file_chunk", "file_abort" },
            sentTypes);
    }

    [Fact]
    public async Task CanceledOutboundDispatchUsesIndependentBoundedTerminationToken()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        string filePath = System.IO.Path.Combine(temp.Path, "cancel-outbound.bin");
        File.WriteAllBytes(filePath, new byte[] { 0x24 });
        using CancellationTokenSource sendCancellation =
            CancellationTokenSource.CreateLinkedTokenSource(TestContext.Current.CancellationToken);
        var sentTypes = new List<string>();
        bool? cleanupTokenWasCanceled = null;

        Task SendAsync(ChatMessage message, CancellationToken cancellationToken)
        {
            sentTypes.Add(message.Type);
            if (string.Equals(message.Type, "file_chunk", StringComparison.Ordinal))
            {
                sendCancellation.Cancel();
                return Task.FromCanceled(sendCancellation.Token);
            }
            if (string.Equals(message.Type, "file_abort", StringComparison.Ordinal))
            {
                cleanupTokenWasCanceled = cancellationToken.IsCancellationRequested;
            }
            return Task.CompletedTask;
        }

        await Assert.ThrowsAnyAsync<OperationCanceledException>(
            () => service.SendFileConfirmedAsync(
                filePath,
                "peer:11111111111111111111111111111111",
                "Sender",
                "A1B2",
                isGroup: false,
                conversationId: "peer:22222222222222222222222222222222",
                sendAsync: SendAsync,
                waitForAcknowledgementAsync: (_, _) => Task.FromException<FileTransferAcknowledgement>(
                    new InvalidOperationException("acknowledgement must not be awaited")),
                cancellationToken: sendCancellation.Token));

        Assert.Equal(new[] { "file_start", "file_chunk", "file_abort" }, sentTypes);
        Assert.False(cleanupTokenWasCanceled);
    }

    [Fact]
    public async Task SenderAbortIsExactEnvelopeBoundAndIdempotent()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(1);
        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);

        ChatMessage wrongEnvelope = CreateAbort(start);
        wrongEnvelope.ConversationId = "peer:33333333333333333333333333333333";
        await Assert.ThrowsAsync<InvalidDataException>(
            () => service.HandleFileAbortAsync(
                wrongEnvelope,
                source,
                TestContext.Current.CancellationToken));
        Assert.Single(Directory.EnumerateFiles(service.AttachmentsDirectory, ".incoming-*.part"));

        Assert.True(await service.HandleFileAbortAsync(
            CreateAbort(start),
            source,
            TestContext.Current.CancellationToken));
        Assert.False(await service.HandleFileAbortAsync(
            CreateAbort(start),
            source,
            TestContext.Current.CancellationToken));
        Assert.Empty(Directory.EnumerateFiles(service.AttachmentsDirectory, ".incoming-*.part"));
    }

    [Fact]
    public async Task AbortAfterCompletionIsNoOpAndNeverDeletesCompletedFile()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(0);
        await service.HandleFileStartAsync(start, source, TestContext.Current.CancellationToken);
        await service.HandleFileChunkAsync(
            CreateChunk(start, 0, ""),
            source,
            TestContext.Current.CancellationToken);
        FileTransferDisplayResult completed = Assert.IsType<FileTransferDisplayResult>(
            await service.HandleFileEndAsync(
                CreateEnd(start),
                source,
                TestContext.Current.CancellationToken));

        Assert.False(await service.HandleFileAbortAsync(
            CreateAbort(start),
            source,
            TestContext.Current.CancellationToken));
        Assert.True(File.Exists(completed.LocalFilePath));
    }

