    [Fact]
    public async Task ExpirationCleanupDoesNotDeleteSessionWhileChunkGateIsHeld()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(0);
        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);

        FieldInfo sessionsField = typeof(FileTransferService).GetField(
            "_incomingFiles",
            BindingFlags.NonPublic | BindingFlags.Instance)
            ?? throw new MissingFieldException(typeof(FileTransferService).FullName, "_incomingFiles");
        IDictionary sessions = Assert.IsAssignableFrom<IDictionary>(sessionsField.GetValue(service));
        object session = Assert.Single(sessions.Values.Cast<object>());
        Type sessionType = session.GetType();
        sessionType.GetProperty("LastActivityUtc")!.SetValue(session, DateTime.UtcNow.AddHours(-1));
        var gate = Assert.IsType<SemaphoreSlim>(sessionType.GetProperty("Gate")!.GetValue(session));

        gate.Wait(TestContext.Current.CancellationToken);
        try
        {
            service.EnsureStorageReady();
            Assert.Single(sessions.Values.Cast<object>());
        }
        finally
        {
            gate.Release();
        }

        await service.HandleFileChunkAsync(
            CreateChunk(start, 0, ""),
            source,
            TestContext.Current.CancellationToken);
        FileTransferDisplayResult completed = Assert.IsType<FileTransferDisplayResult>(
            await service.HandleFileEndAsync(
                CreateEnd(start),
                source,
                TestContext.Current.CancellationToken));
        Assert.True(File.Exists(completed.LocalFilePath));
    }

    [Fact]
    public async Task ExactAbortFinishesCleanupAfterOwnershipTransferEvenIfCallerCancels()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(1);
        await service.HandleFileStartAsync(start, source, TestContext.Current.CancellationToken);

        FieldInfo sessionsField = typeof(FileTransferService).GetField(
            "_incomingFiles",
            BindingFlags.NonPublic | BindingFlags.Instance)
            ?? throw new MissingFieldException(typeof(FileTransferService).FullName, "_incomingFiles");
        IDictionary sessions = Assert.IsAssignableFrom<IDictionary>(sessionsField.GetValue(service));
        object session = Assert.Single(sessions.Values.Cast<object>());
        var gate = Assert.IsType<SemaphoreSlim>(session.GetType().GetProperty("Gate")!.GetValue(session));
        using var cancellation = CancellationTokenSource.CreateLinkedTokenSource(
            TestContext.Current.CancellationToken);

        gate.Wait(TestContext.Current.CancellationToken);
        Task<bool> abort = service.AbortIncomingTransferAsync(start.FileId!, source, cancellation.Token);
        cancellation.Cancel();
        Assert.False(abort.IsCompleted);
        gate.Release();

        Assert.True(await abort);
        Assert.Empty(sessions.Values.Cast<object>());
        Assert.Empty(Directory.EnumerateFiles(service.AttachmentsDirectory, ".incoming-*.part"));
    }

    [Fact]
    public async Task CrowdedFileNamesUseBoundedRandomFallback()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        for (int index = 0; index <= 32; index++)
        {
            string name = index == 0 ? "same.bin" : $"same_{index}.bin";
            File.WriteAllBytes(System.IO.Path.Combine(service.AttachmentsDirectory, name), Array.Empty<byte>());
        }

        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(0);
        start.FileName = "same.bin";
        await service.HandleFileStartAsync(
            start,
            source,
            TestContext.Current.CancellationToken);
        await service.HandleFileChunkAsync(
            CreateChunk(start, 0, ""),
            source,
            TestContext.Current.CancellationToken);
        FileTransferDisplayResult completed = Assert.IsType<FileTransferDisplayResult>(
            await service.HandleFileEndAsync(
                CreateEnd(start),
                source,
                TestContext.Current.CancellationToken));

        Assert.StartsWith("same_", System.IO.Path.GetFileName(completed.LocalFilePath), StringComparison.Ordinal);
        Assert.DoesNotContain("same_33.bin", completed.LocalFilePath, StringComparison.OrdinalIgnoreCase);
    }

    [Theory]
    [InlineData(".incoming-0123456789abcdef-11111111111111111111111111111111-22222222222222222222222222222222.part")]
    [InlineData(".migration-11111111111111111111111111111111.tmp")]
    public async Task RemoteFinalNameCannotEnterServiceTemporaryNamespace(string wireName)
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        const string source = "authenticated:peer-a";
        ChatMessage start = CreateStart(0);
        start.FileName = wireName;
        await service.HandleFileStartAsync(start, source, TestContext.Current.CancellationToken);
        await service.HandleFileChunkAsync(
            CreateChunk(start, 0, ""),
            source,
            TestContext.Current.CancellationToken);
        FileTransferDisplayResult completed = Assert.IsType<FileTransferDisplayResult>(
            await service.HandleFileEndAsync(
                CreateEnd(start),
                source,
                TestContext.Current.CancellationToken));

        Assert.StartsWith("_", completed.FileName, StringComparison.Ordinal);
        Assert.StartsWith("_", System.IO.Path.GetFileName(completed.LocalFilePath), StringComparison.Ordinal);
    }

    [Fact]
    public void RetainedQuotaCountsTemporaryLookingArtifacts()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        string crafted = System.IO.Path.Combine(
            service.AttachmentsDirectory,
            ".incoming-0123456789abcdef-11111111111111111111111111111111-22222222222222222222222222222222.part");
        File.WriteAllBytes(crafted, Array.Empty<byte>());

        MethodInfo refresh = typeof(FileTransferService).GetMethod(
            "RefreshRetainedAttachmentCount",
            BindingFlags.NonPublic | BindingFlags.Instance)
            ?? throw new MissingMethodException(
                typeof(FileTransferService).FullName,
                "RefreshRetainedAttachmentCount");
        refresh.Invoke(service, null);
        FieldInfo retained = typeof(FileTransferService).GetField(
            "_retainedAttachmentCount",
            BindingFlags.NonPublic | BindingFlags.Instance)
            ?? throw new MissingFieldException(
                typeof(FileTransferService).FullName,
                "_retainedAttachmentCount");

        Assert.Equal(1, retained.GetValue(service));
    }

    [Fact]
    public async Task RetainedByteQuotaRejectsNewInboundPersistence()
    {
        using var temp = new TestDirectory();
        string attachments = temp.CreateSubdirectory("byte-quota-attachments");
        string retainedPath = System.IO.Path.Combine(attachments, "retained.bin");
        using (var retained = new FileStream(
                   retainedPath,
                   FileMode.CreateNew,
                   FileAccess.Write,
                   FileShare.None))
        {
            retained.SetLength(FileTransferService.MaxRetainedAttachmentBytes);
        }
        var service = new FileTransferService(
            attachments,
            temp.CreateSubdirectory("byte-quota-downloads"),
            temp.CreateSubdirectory("byte-quota-outgoing"));
        service.EnsureStorageReady();

        IOException rejected = await Assert.ThrowsAsync<IOException>(
            () => service.HandleFileStartAsync(
                CreateStart(1),
                "authenticated:peer-byte-quota",
                TestContext.Current.CancellationToken));

        Assert.Contains("byte limit", rejected.Message, StringComparison.OrdinalIgnoreCase);
        Assert.Single(Directory.EnumerateFiles(attachments));
    }

    [Fact]
    public void OutgoingCacheQuotaEvictsOldSnapshotsButProtectsCurrentSend()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        string outgoing = temp.Path + System.IO.Path.DirectorySeparatorChar + "outgoing";
        string oldPath = System.IO.Path.Combine(outgoing, "old.bin");
        string currentPath = System.IO.Path.Combine(outgoing, "current.bin");
        using (var old = new FileStream(oldPath, FileMode.CreateNew, FileAccess.Write, FileShare.None))
        {
            old.SetLength(FileTransferService.MaxOutgoingCacheBytes);
        }
        File.WriteAllBytes(currentPath, new byte[] { 1 });

        MethodInfo cleanup = typeof(FileTransferService).GetMethod(
            "CleanupOutgoingCache",
            BindingFlags.NonPublic | BindingFlags.Instance)
            ?? throw new MissingMethodException(
                typeof(FileTransferService).FullName,
                "CleanupOutgoingCache");
        cleanup.Invoke(service, new object?[] { currentPath });

        Assert.False(File.Exists(oldPath));
        Assert.True(File.Exists(currentPath));
        Assert.Single(Directory.EnumerateFiles(outgoing));
    }

    [Fact]
    public async Task DownloadsCopyRejectsOversizedSourceBeforeCreatingOutput()
    {
        using var temp = new TestDirectory();
        FileTransferService service = CreateService(temp);
        string source = System.IO.Path.Combine(temp.Path, "oversized.bin");
        using (var stream = new FileStream(source, FileMode.CreateNew, FileAccess.Write, FileShare.None))
        {
            stream.SetLength(FileTransferService.MaxFileSizeBytes + 1);
        }

        await Assert.ThrowsAsync<InvalidDataException>(
            () => service.SaveToDownloadsAsync(
                source,
                "oversized.bin",
                TestContext.Current.CancellationToken));
        Assert.Empty(Directory.EnumerateFiles(service.DownloadsDirectory));
    }

    private static FileTransferService CreateService(TestDirectory temp)
    {
        var service = new FileTransferService(
            temp.CreateSubdirectory("attachments"),
            temp.CreateSubdirectory("downloads"),
            temp.CreateSubdirectory("outgoing"));
        service.EnsureStorageReady();
        return service;
    }

    private static ChatMessage CreateStart(long fileSize) => new()
    {
        Type = "file_start",
        SenderId = "peer:11111111111111111111111111111111",
        SenderName = "Sender",
        ShortSessionId = "A1B2",
        ConversationId = "peer:22222222222222222222222222222222",
        FileId = Guid.NewGuid().ToString("N"),
        FileName = "sample.bin",
        FileSize = fileSize,
        ChunkCount = fileSize == 0
            ? 1
            : checked((int)((fileSize + FileTransferService.TransferChunkSize - 1) /
                            FileTransferService.TransferChunkSize))
    };

    private static ChatMessage CreateChunk(
        ChatMessage start,
        int chunkIndex,
        string base64)
    {
        ChatMessage message = CreateFollowup(start, "file_chunk");
        message.ChunkIndex = chunkIndex;
        message.ChunkBase64 = base64;
        return message;
    }

    private static ChatMessage CreateEnd(ChatMessage start) =>
        CreateFollowup(start, "file_end");

    private static ChatMessage CreateAbort(ChatMessage start) =>
        CreateFollowup(start, "file_abort");

    private static ChatMessage CreateFollowup(ChatMessage start, string type) => new()
    {
        Type = type,
        SenderId = start.SenderId,
        SenderName = start.SenderName,
        ShortSessionId = start.ShortSessionId,
        IsGroup = start.IsGroup,
        ConversationId = start.ConversationId,
        FileId = start.FileId,
        FileName = start.FileName,
        FileSize = start.FileSize,
        ChunkCount = start.ChunkCount,
        RelaySenderId = start.RelaySenderId,
        RelaySenderName = start.RelaySenderName,
        RelayShortSessionId = start.RelayShortSessionId,
        HopCount = start.HopCount
    };

    private static void MutateEnvelope(ChatMessage message, string mutation)
    {
        switch (mutation)
        {
            case "group":
                message.IsGroup = !message.IsGroup;
                break;
            case "conversation":
                message.ConversationId = "peer:33333333333333333333333333333333";
                break;
            case "size":
                message.FileSize = (message.FileSize ?? 0) + 1;
                break;
            case "count":
                message.ChunkCount = (message.ChunkCount ?? 0) + 1;
                break;
            case "name":
                message.FileName = "different.bin";
                break;
            case "size-null":
                message.FileSize = null;
                break;
            case "count-null":
                message.ChunkCount = null;
                break;
            case "name-null":
                message.FileName = null;
                break;
            default:
                throw new ArgumentOutOfRangeException(nameof(mutation));
        }
    }
}
