<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="direct_module.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Hide Chat"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <SolidColorBrush x:Key="AppInkBrush" Color="#F3F7FA" />
            <SolidColorBrush x:Key="MutedInkBrush" Color="#A8B5BE" />
            <SolidColorBrush x:Key="SubtleInkBrush" Color="#6F7E89" />
            <SolidColorBrush x:Key="PanelBrush" Color="#9911161C" />
            <SolidColorBrush x:Key="PanelStrongBrush" Color="#D012171E" />
            <SolidColorBrush x:Key="PanelSoftBrush" Color="#66192028" />
            <SolidColorBrush x:Key="StrokeBrush" Color="#24313B45" />
            <SolidColorBrush x:Key="StrokeBrightBrush" Color="#334B6574" />
            <SolidColorBrush x:Key="AccentBrush" Color="#00D6FF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#2A00D6FF" />
            <SolidColorBrush x:Key="LimeBrush" Color="#B8FF6A" />
            <SolidColorBrush x:Key="LimeSoftBrush" Color="#2CB8FF6A" />
            <SolidColorBrush x:Key="IncomingBubbleBrush" Color="#E01A222C" />
            <SolidColorBrush x:Key="InputBrush" Color="#D0161D25" />

            <LinearGradientBrush x:Key="PageGlowBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2213E8FF" Offset="0" />
                <GradientStop Color="#0611161C" Offset="0.45" />
                <GradientStop Color="#1A9FFF68" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="OutgoingBubbleBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF00C7F2" Offset="0" />
                <GradientStop Color="#FF3FF087" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="TinyLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource SubtleInkBrush}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="MetaTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="IconOnlyButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
                <Setter Property="Background" Value="#20182028" />
                <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="34" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Foreground" Value="{StaticResource MutedInkBrush}" />
                <Setter Property="Background" Value="#18182028" />
                <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </Grid.Resources>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0A0D12" Offset="0" />
                <GradientStop Color="#FF0F151C" Offset="0.45" />
                <GradientStop Color="#FF09110D" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Rectangle Fill="{StaticResource PageGlowBrush}" Opacity="0.95" />

        <Grid Margin="16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="460" />
                <ColumnDefinition Width="320" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="22">
                <Grid Padding="18" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="44" Height="44" BorderBrush="#5500D6FF" BorderThickness="1" CornerRadius="14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF00D6FF" Offset="0" />
                                    <GradientStop Color="#FFB8FF6A" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="17"
                                FontWeight="Bold"
                                Foreground="#FF081018"
                                Text="H" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Hide Chat" />
                            <TextBlock x:Name="PeerCountText" Style="{StaticResource MetaTextStyle}" Text="検出済み 0 / 接続待機" />
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            Click="SearchPeers_Click"
                            Style="{StaticResource IconOnlyButtonStyle}"
                            ToolTipService.ToolTip="相手を探す">
                            <FontIcon FontSize="16" Glyph="&#xE721;" />
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="PeerList"
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        IsItemClickEnabled="False"
                        SelectionChanged="PeerList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,9"
                                    Padding="12"
                                    Background="{StaticResource PanelSoftBrush}"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid>
                                            <Ellipse Width="42" Height="42" Fill="#FF182732" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource AccentBrush}"
                                                Text="WD" />
                                        </Grid>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource AppInkBrush}"
                                                Text="{Binding DisplayName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource MutedInkBrush}"
                                                MaxLines="2"
                                                Text="{Binding DisplayText}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Button
                                            Grid.Column="2"
                                            Background="{StaticResource LimeSoftBrush}"
                                            BorderBrush="#77B8FF6A"
                                            BorderThickness="1"
                                            Click="ConnectPeerItem_Click"
                                            Foreground="{StaticResource LimeBrush}"
                                            IsEnabled="{Binding CanConnect}"
                                            Opacity="{Binding ConnectButtonOpacity}"
                                            Style="{StaticResource IconOnlyButtonStyle}"
                                            ToolTipService.ToolTip="接続">
                                            <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border
                        Grid.Row="2"
                        Padding="12"
                        Background="#26192028"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="34" Height="34" Fill="#FF00D6FF" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="Local node" />
                                <TextBlock FontSize="11" Foreground="{StaticResource LimeBrush}" Text="Wi-Fi Direct / BLE / TCP" />
                            </StackPanel>
                            <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource MutedInkBrush}" Glyph="&#xE713;" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Background="{StaticResource PanelStrongBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="116" />
                    </Grid.RowDefinitions>

                    <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="22,0">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid VerticalAlignment="Center">
                                <Ellipse Width="48" Height="48" Fill="#FF182732" />
                                <TextBlock
                                    x:Name="ChatHeaderAvatarText"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="WD" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Margin="0,0,1,1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Fill="{StaticResource LimeBrush}"
                                    Stroke="#FF11161C"
                                    StrokeThickness="2" />
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock
                                    x:Name="ChatHeaderTitleText"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppInkBrush}"
                                    Text="Wi-Fi Direct Chat" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="ChatHeaderStatusText" Style="{StaticResource MetaTextStyle}" Text="相手を選択してください" />
                                    <TextBlock Style="{StaticResource MetaTextStyle}" Text="•" />
                                    <TextBlock Foreground="{StaticResource LimeBrush}" FontSize="12" Text="TCP 50001" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button
                                    x:Name="GroupChatButton"
                                    Click="SwitchToGroupChat_Click"
                                    Content="グループ"
                                    IsEnabled="False"
                                    Style="{StaticResource GhostButtonStyle}"
                                    ToolTipService.ToolTip="接続中の全員へ送信" />
                                <Button
                                    Click="StartTcpServer_Click"
                                    Style="{StaticResource IconOnlyButtonStyle}"
                                    ToolTipService.ToolTip="TCP待ち受け">
                                    <FontIcon FontSize="16" Glyph="&#xE968;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView
                        x:Name="MessageList"
                        Grid.Row="1"
                        Padding="22,18"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid VerticalAlignment="Top">
                                        <Ellipse Width="34" Height="34" Fill="#FF25203A" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="#FFC9B8FF"
                                            Text="TX" />
                                    </Grid>
                                    <Border
                                        Grid.Column="1"
                                        MaxWidth="640"
                                        HorizontalAlignment="Left"
                                        Padding="14,11"
                                        Background="{StaticResource IncomingBubbleBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4,16,16,16">
                                        <StackPanel Spacing="8">
                                            <TextBlock
                                                FontSize="14"
                                                Foreground="{StaticResource AppInkBrush}"
                                                Text="{Binding Text}"
                                                TextWrapping="Wrap" />
                                            <Image
                                                MaxWidth="360"
                                                MaxHeight="260"
                                                HorizontalAlignment="Left"
                                                Source="{Binding ImageSource}"
                                                Stretch="Uniform"
                                                Visibility="{Binding ImageVisibility}" />
                                            <StackPanel
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                Visibility="{Binding FileButtonVisibility}">
                                                <Button
                                                    Click="OpenAttachmentButton_Click"
                                                    Content="開く"
                                                    Style="{StaticResource GhostButtonStyle}" />
                                                <Button
                                                    Click="SaveAttachmentButton_Click"
                                                    Content="保存"
                                                    Style="{StaticResource GhostButtonStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Grid.Row="2" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,1,0,0" Padding="18">
                        <Grid
                            Padding="12"
                            Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource StrokeBrightBrush}"
                            BorderThickness="1"
                            ColumnSpacing="10"
                            CornerRadius="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="AttachFileButton"
                                Click="AttachFileButton_Click"
                                Style="{StaticResource IconOnlyButtonStyle}"
                                ToolTipService.ToolTip="ファイルを送信">
                                <FontIcon FontSize="20" Glyph="&#xE710;" />
                            </Button>
                            <TextBox
                                x:Name="MessageTextBox"
                                Grid.Column="1"
                                MinHeight="42"
                                KeyDown="MessageTextBox_KeyDown"
                                VerticalAlignment="Center"
                                AcceptsReturn="False"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14"
                                Foreground="{StaticResource AppInkBrush}"
                                PlaceholderText="メッセージを入力..." />
                            <Button
                                x:Name="SendMessageButton"
                                Grid.Column="3"
                                Width="46"
                                Height="42"
                                Padding="0"
                                BorderBrush="#8800D6FF"
                                BorderThickness="1"
                                Click="SendMessage_Click"
                                CornerRadius="14"
                                Foreground="#FF061016"
                                ToolTipService.ToolTip="送信">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF00D6FF" Offset="0" />
                                        <GradientStop Color="#FFB8FF6A" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                                <FontIcon FontSize="17" Glyph="&#xE724;" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border
                Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="22">
                <Grid Padding="18" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16">
                            <Grid>
                                <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="詳細" />
                            </Grid>

                            <StackPanel HorizontalAlignment="Center" Spacing="10">
                                <Grid>
                                    <Ellipse Width="96" Height="96" Fill="#FF182732" />
                                    <TextBlock
                                        x:Name="SelectedPeerAvatarText"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="28"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource AccentBrush}"
                                        Text="WD" />
                                    <Ellipse
                                        x:Name="SelectedPeerOnlineDot"
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,8,8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Fill="{StaticResource SubtleInkBrush}"
                                        Stroke="#FF11161C"
                                        StrokeThickness="3" />
                                </Grid>
                                <TextBlock
                                    x:Name="SelectedPeerNameText"
                                    HorizontalAlignment="Center"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppInkBrush}"
                                    Text="未選択"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                                <Border
                                    Padding="10,5"
                                    Background="{StaticResource LimeSoftBrush}"
                                    BorderBrush="#55B8FF6A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <TextBlock
                                        x:Name="SelectedPeerStatusText"
                                        FontSize="12"
                                        Foreground="{StaticResource LimeBrush}"
                                        Text="相手を選択してください" />
                                </Border>
                            </StackPanel>

                            <Button
                                x:Name="ReconnectButton"
                                Content="再接続"
                                Click="ReconnectButton_Click"
                                IsEnabled="False"
                                Style="{StaticResource GhostButtonStyle}" />

                            <Border
                                Padding="14"
                                Background="{StaticResource PanelSoftBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppInkBrush}" Text="接続状態" />
                                    <TextBlock
                                        x:Name="SelectedPeerSourceText"
                                        FontSize="13"
                                        Foreground="{StaticResource MutedInkBrush}"
                                        Text="BLE / Wi-Fi Direct の検出状況がここに表示されます。"
                                        TextWrapping="Wrap" />
                                    <ProgressBar
                                        x:Name="SelectedPeerProgress"
                                        Height="6"
                                        Maximum="100"
                                        Value="10"
                                        Background="#22313B45"
                                        Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="10">
                                <TextBlock Style="{StaticResource TinyLabelStyle}" Text="NETWORK" />
                                <Border
                                    Padding="12"
                                    Background="{StaticResource PanelSoftBrush}"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            x:Name="SelectedPeerIpText"
                                            FontSize="13"
                                            Foreground="{StaticResource AppInkBrush}"
                                            Text="Remote IP: -" />
                                        <TextBlock
                                            x:Name="SelectedPeerSessionText"
                                            FontSize="12"
                                            Foreground="{StaticResource MutedInkBrush}"
                                            Text="Session: -" />
                                        <TextBlock
                                            x:Name="SelectedPeerDeviceText"
                                            FontSize="12"
                                            Foreground="{StaticResource MutedInkBrush}"
                                            Text="DeviceId: -"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Expander Header="診断操作" IsExpanded="False">
                                <StackPanel Padding="0,12,0,0" Spacing="10">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Click="SearchPeers_Click" Content="相手を探す" Style="{StaticResource GhostButtonStyle}" />
                                        <Button Grid.Column="1" Click="StartListener_Click" Content="待ち受け" Style="{StaticResource GhostButtonStyle}" />
                                    </Grid>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="1" Click="SearchDefaultButton_Click" Content="通常探索" Style="{StaticResource GhostButtonStyle}" />
                                    </Grid>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Click="StartBleAdvertise_Click" Content="BLE広告" Style="{StaticResource GhostButtonStyle}" />
                                        <Button Grid.Column="1" Click="StartBleScan_Click" Content="BLEスキャン" Style="{StaticResource GhostButtonStyle}" />
                                    </Grid>

                                    <TextBox
                                        x:Name="TargetIpTextBox"
                                        MinHeight="38"
                                        Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="1"
                                        Foreground="{StaticResource AppInkBrush}"
                                        PlaceholderText="手入力IP 例: 192.168.1.23" />

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Click="StartTcpServer_Click" Content="TCP待ち受け" Style="{StaticResource GhostButtonStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource TinyLabelStyle}" Text="LOG" />
                            <CheckBox
                                x:Name="ShowDebugLogCheckBox"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Content="詳細ログ"
                                Foreground="{StaticResource MutedInkBrush}"
                                IsChecked="False" />
                            <Button
                                Grid.Column="2"
                                Click="ClearLog_Click"
                                Content="ログ消去"
                                Style="{StaticResource GhostButtonStyle}" />
                            <Button
                                Grid.Column="3"
                                Click="ScrollLogBottom_Click"
                                Style="{StaticResource IconOnlyButtonStyle}"
                                ToolTipService.ToolTip="ログ末尾へ">
                                <FontIcon FontSize="15" Glyph="&#xE70D;" />
                            </Button>
                        </Grid>

                        <TextBox
                            x:Name="LogTextBox"
                            Grid.Row="1"
                            AcceptsReturn="True"
                            Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            FontFamily="Consolas"
                            FontSize="12"
                            Foreground="{StaticResource MutedInkBrush}"
                            IsReadOnly="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            TextWrapping="NoWrap" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
